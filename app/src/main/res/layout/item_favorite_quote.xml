<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/card_bg"
    android:padding="20dp"
    android:layout_marginBottom="12dp"
    android:layout_marginHorizontal="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="10dp">

        <TextView
            android:id="@+id/tv_fav_category"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="WISDOM"
            android:textColor="@color/accent_blue_light"
            android:textSize="10sp"
            android:letterSpacing="0.15"/>

        <ImageButton
            android:id="@+id/btn_fav_share"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@android:drawable/ic_menu_share"
            android:background="@color/btn_bg"
            android:padding="8dp"
            android:contentDescription="Share"
            android:layout_marginEnd="8dp"/>

        <ImageButton
            android:id="@+id/btn_fav_remove"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@android:drawable/ic_menu_delete"
            android:background="@color/btn_bg"
            android:padding="8dp"
            android:contentDescription="Remove from Favorites"/>
    </LinearLayout>

    <TextView
        android:id="@+id/tv_fav_quote"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/text_primary"
        android:textSize="16sp"
        android:fontFamily="serif"
        android:textStyle="italic"
        android:lineSpacingMultiplier="1.4"
        android:layout_marginBottom="12dp"/>

    <View
        android:layout_width="32dp"
        android:layout_height="1.5dp"
        android:background="@color/divider"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/tv_fav_author"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/text_muted"
        android:textSize="13sp"/>

</LinearLayout>