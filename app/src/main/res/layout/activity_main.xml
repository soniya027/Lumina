<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_deep">

    <!-- Top bar -->
    <LinearLayout
        android:id="@+id/top_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:paddingTop="52dp"
        android:paddingBottom="12dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="✦ Lumina"
            android:textColor="@color/text_primary"
            android:textSize="22sp"
            android:fontFamily="serif"
            android:textStyle="bold"/>

        <ImageButton
            android:id="@+id/btn_view_favorites"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@android:drawable/btn_star_big_off"
            android:background="@color/card_bg"
            android:padding="10dp"
            android:contentDescription="View Favorites"/>
    </LinearLayout>

    <!-- Day label -->
    <TextView
        android:id="@+id/tv_day_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="QUOTE OF THE DAY"
        android:textColor="@color/accent_blue_light"
        android:textSize="11sp"
        android:letterSpacing="0.18"
        android:paddingHorizontal="12dp"
        android:paddingVertical="5dp"
        android:background="@color/background_mid"
        app:layout_constraintTop_toBottomOf="@id/top_bar"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginStart="24dp"
        android:layout_marginTop="4dp"/>

    <!-- Quote card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/card_quote"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="@color/card_bg"
        android:layout_marginHorizontal="20dp"
        app:layout_constraintTop_toBottomOf="@id/tv_day_label"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="28dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="&#8220;"
                android:textColor="@color/accent_blue_light"
                android:textSize="48sp"
                android:fontFamily="serif"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tv_quote"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="The future belongs to those who believe in the beauty of their dreams."
                android:textColor="@color/text_primary"
                android:textSize="20sp"
                android:fontFamily="serif"
                android:lineSpacingMultiplier="1.45"
                android:textStyle="italic"
                android:layout_marginBottom="24dp"/>

            <View
                android:layout_width="40dp"
                android:layout_height="2dp"
                android:background="@color/accent_blue_light"
                android:layout_marginBottom="14dp"/>

            <TextView
                android:id="@+id/tv_author"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="— Eleanor Roosevelt"
                android:textColor="@color/text_secondary"
                android:textSize="15sp"
                android:layout_marginBottom="6dp"/>

            <TextView
                android:id="@+id/tv_category"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DREAMS"
                android:textColor="@color/accent_blue_light"
                android:textSize="10sp"
                android:letterSpacing="0.15"
                android:layout_marginBottom="24dp"/>

            <!-- Action buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <ImageButton
                    android:id="@+id/btn_favorite"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:src="@android:drawable/btn_star_big_off"
                    android:background="@color/btn_bg"
                    android:padding="12dp"
                    android:contentDescription="Save to Favorites"
                    android:layout_marginEnd="12dp"/>

                <ImageButton
                    android:id="@+id/btn_share"
                    android:layout_width="68dp"
                    android:layout_height="68dp"
                    android:src="@android:drawable/ic_menu_share"
                    android:background="@color/accent_blue"
                    android:padding="16dp"
                    android:contentDescription="Share Quote"
                    android:layout_marginEnd="12dp"/>

                <ImageButton
                    android:id="@+id/btn_refresh"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:src="@android:drawable/ic_popup_sync"
                    android:background="@color/btn_bg"
                    android:padding="12dp"
                    android:contentDescription="New Random Quote"/>

            </LinearLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Bottom hint -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tap ↻ for a new quote"
        android:textColor="@color/text_dim"
        android:textSize="12sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="28dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>